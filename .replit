modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Control Panel"

[[workflows.workflow]]
name = "Control Panel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash control_panel.sh"

[workflows.workflow.metadata]
outputType = "console"
